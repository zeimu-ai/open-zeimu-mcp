{
  "name": "@zeimu-ai/open-zeimu-mcp",
  "version": "0.1.0-alpha.0",
  "description": "OSS MCP server for Japanese tax primary sources (法令・通達・タックスアンサー・質疑応答事例・文書回答事例・裁決事例)",
  "type": "module",
  "license": "MIT",
  "author": "Zeimu AI <oss@zeimu.ai>",
  "bin": {
    "open-zeimu-mcp": "./dist/index.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zeimu-ai/open-zeimu-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/zeimu-ai/open-zeimu-mcp/issues"
  },
  "homepage": "https://github.com/zeimu-ai/open-zeimu-mcp#readme",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "tax",
    "japan",
    "open-data",
    "lexical-search",
    "zeimu-ai"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/",
    "data/",
    "README.md",
    "README.ja.md",
    "LICENSE",
    "NOTICE"
  ],
  "scripts": {
    "lint": "npm run lint:md && npm run lint:yaml",
    "lint:md": "node ./node_modules/markdownlint-cli2/markdownlint-cli2.mjs '**/*.md' '!node_modules'",
    "lint:yaml": "yamllint .",
    "start": "node ./node_modules/tsx/dist/cli.mjs src/index.ts",
    "crawl:tax-answer": "node ./node_modules/tsx/dist/cli.mjs src/crawler/tax-answer/cli.ts",
    "crawl:qa-case": "node ./node_modules/tsx/dist/cli.mjs src/crawler/qa-case/cli.ts",
    "crawl:written-answer": "node ./node_modules/tsx/dist/cli.mjs src/crawler/written-answer/cli.ts",
    "crawl:tsutatsu": "node ./node_modules/tsx/dist/cli.mjs src/crawler/tsutatsu/cli.ts",
    "crawl:saiketsu": "node ./node_modules/tsx/dist/cli.mjs src/crawler/saiketsu/cli.ts",
    "precompute:embeddings": "node ./node_modules/tsx/dist/cli.mjs scripts/precompute-embeddings.ts",
    "release:vectors": "node ./node_modules/tsx/dist/cli.mjs scripts/release-vectors.ts",
    "typecheck": "node ./node_modules/typescript/bin/tsc --noEmit",
    "test": "node ./node_modules/vitest/vitest.mjs run",
    "test:watch": "node ./node_modules/vitest/vitest.mjs",
    "test:coverage": "node ./node_modules/vitest/vitest.mjs run --coverage",
    "build": "node ./node_modules/typescript/bin/tsc -p tsconfig.json",
    "release": "changeset publish",
    "release:dry-run": "npm publish --dry-run --access public"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@huggingface/tokenizers": "^0.1.3",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "fast-glob": "^3.3.3",
    "gray-matter": "^4.0.3",
    "minisearch": "^7.2.0",
    "pino": "^10.3.1",
    "zod": "^4.3.6"
  },
  "optionalDependencies": {
    "onnxruntime-node": "^1.24.3"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@types/node": "^22.17.2",
    "markdownlint-cli2": "^0.22.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  }
}
