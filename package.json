{
  "name": "@zeimu-ai/open-zeimu-mcp",
  "version": "0.1.0-alpha.0",
  "description": "OSS MCP server for Japanese tax primary sources (法令・通達・タックスアンサー・質疑応答事例・文書回答事例・裁決事例)",
  "type": "module",
  "license": "MIT",
  "author": "Zeimu AI <oss@zeimu.ai>",
  "bin": {
    "open-zeimu-mcp": "./dist/index.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zeimu-ai/open-zeimu-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/zeimu-ai/open-zeimu-mcp/issues"
  },
  "homepage": "https://github.com/zeimu-ai/open-zeimu-mcp#readme",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "tax",
    "japan",
    "open-data",
    "lexical-search",
    "zeimu-ai"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/",
    "data/",
    "README.md",
    "README.ja.md",
    "LICENSE",
    "NOTICE"
  ],
  "scripts": {
    "lint": "npm run lint:md && npm run lint:yaml",
    "lint:md": "markdownlint-cli2 '**/*.md' '!node_modules'",
    "lint:yaml": "yamllint .",
    "start": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "build": "tsc -p tsconfig.json",
    "release": "changeset publish"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "fast-glob": "^3.3.3",
    "gray-matter": "^4.0.3",
    "minisearch": "^7.2.0",
    "pino": "^10.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@types/node": "^22.17.2",
    "markdownlint-cli2": "^0.12.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^1.6.1"
  }
}
